<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             x:Class="mobile_app.View.EditTermPage"
             Title="EditTermPage">

    <ScrollView>
    <VerticalStackLayout Margin="0,50,0,0">
       
        <Entry x:Name="TermName"
           Text="{Binding Name}"
           Margin="20"/>

        <Label Text="Edit start date:"
           Margin="20,0"/>
        <DatePicker x:Name="TermStartDate"
                Format="MM/dd/yyyy"
                Date="{Binding StartDate}"
                Margin="20,0"/>

        <Label Text="Edit end date:"
           Margin="20,20,20,0"/>
        <DatePicker x:Name="TermEndDate"
                Format="MM/dd/yyyy"
                Date="{Binding EndDate}"
                Margin="20,0,20,20"/>

        <Grid ColumnDefinitions="*,*">
            <Button Grid.Column="0"
                Text="Save"
                Clicked="OnSaveEditTerm"
                BackgroundColor="#426929"
                Margin="20,0"/>

            <Button Grid.Column="1"
                Text="Delete"
                    Clicked="OnDeleteTerm"
                Margin="20,0"/>
        </Grid>

    </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>