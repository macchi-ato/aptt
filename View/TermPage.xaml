<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mobile_app.View.TermPage"
             Title="TermPage">
    <ScrollView>
    <Grid RowDefinitions="*,Auto" Margin="0,50,0,0">

        <VerticalStackLayout Grid.Row="0">

            <Grid ColumnDefinitions="*,*,*" BackgroundColor="#426929" HeightRequest="80">
                <Button Grid.Column="0" 
                    Text="←"
                    Clicked="OnBackClick"
                    BackgroundColor="Transparent"
                    FontSize="32"/>
                
                <Label x:Name="TermNameLabel"  Grid.Column="1" 
                    Text=""
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    TextColor="White"
                    FontSize="20"/>

                <Button Grid.Column="2" 
                        Clicked="OnEditClick"
                    Text=". . ."
                    BackgroundColor="Transparent"
                    FontSize="32"/>
            </Grid>

            <VerticalStackLayout >
                <Grid ColumnDefinitions="*,*,*"
                  Padding="20, 20, 20, 6">
                    <Label 
                        Grid.Column="0"
                        Text="Course"/>
                    <Label 
                        Grid.Column="1"
                        Text="Status"/>
                    <Label 
                        Grid.Column="2"
                        Text="Date"/>
                </Grid>

                <BoxView HeightRequest="1"
                    Color="Gray"
                    VerticalOptions="Fill"
                    Margin="20,0"/>
            </VerticalStackLayout>

            <CollectionView x:Name="CourseListView"
                ItemsSource="{Binding Courses}"
                SelectionMode="Single"
                SelectionChanged="OnCourseSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,*,*"
                                Padding="20, 20, 20, 0">
                            <Label Grid.Column="0" 
                                   Text="{Binding Name}"
                                   TextColor="#997304"
                                   FontSize="16"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding Status}"/>
                            <Label Grid.Column="2" 
                                   Text="{Binding DateRange}"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
        </VerticalStackLayout>

        <Button Grid.Row="1" 
            BackgroundColor="#426929"
            Text="Add Course"
            Clicked="OnAddCourseClicked"
            HorizontalOptions="Start"
            Margin="20"
            WidthRequest="120"/>

    </Grid>
    </ScrollView>
    
</ContentPage>