<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mobile_app.View.CoursePage"
             Title="CoursePage">

    <ScrollView>
    <Grid RowDefinitions="*,Auto" Margin="0,50,0,0">

        <VerticalStackLayout Grid.Row="0">

            <Grid ColumnDefinitions="*,*,*" BackgroundColor="#426929" HeightRequest="80">
                <Button Grid.Column="0" 
                    Text="←"
                    Clicked="OnBackClick"
                    BackgroundColor="Transparent"
                    FontSize="32"/>

                <Label x:Name="CourseNameLabel"  Grid.Column="1" 
                    Text=""
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    TextColor="White"
                    FontSize="20"/>

                <Button Grid.Column="2" 
                        Clicked="OnEditClick"
                    Text=". . ."
                    BackgroundColor="Transparent"
                    FontSize="32"/>
            </Grid>

            <VerticalStackLayout BackgroundColor="#B2C3B1" Padding="20">

                <Label
                    Text="Instructor Name:"
                    TextColor="White"
                    FontSize="16"/>
                <Label x:Name="InstructorName"
                    Text=""
                    TextColor="#997304"
                    FontSize="16"
                    Margin="0,0,0,10"/>

                <Label
                    Text="Instructor Phone:"
                    TextColor="White"
                    FontSize="16"/>
                <Label x:Name="InstructorPhone"
                    Text=""
                    TextColor="#997304"
                    FontSize="16"
                       Margin="0,0,0,10"/>

                <Label
                    Text="Instructor Email:"
                    TextColor="White"
                    FontSize="16"/>
                <Label x:Name="InstructorEmail"
                    Text=""
                    TextColor="#997304"
                    FontSize="16"
                    Margin="0,0,0,10"/>

                <Label
                    Text="Notes:"
                    TextColor="White"
                    FontSize="16"/>
                <Label x:Name="Notes"
                    Text=""
                    TextColor="#997304"
                    FontSize="16"
                    Margin="0,0,0,10"/>

                <Grid ColumnDefinitions="*,*">
                    <Label Grid.Column="0"
                        Text="Status:"
                        TextColor="White"
                        FontSize="16"/>
                    <Label Grid.Column="1"
                        Text="Dates:"
                        TextColor="White"
                        FontSize="16"/>
                </Grid>
                
                <Grid ColumnDefinitions="*,*">
                    <Label x:Name="StatusLabel" Grid.Column="0"
                        Text=""
                        TextColor="#997304"
                        FontSize="16"/>
                    <Label x:Name="DateLabel" Grid.Column="1"
                        Text=""
                        TextColor="#997304"
                        FontSize="16"/>
                </Grid>
                
            </VerticalStackLayout>

            <VerticalStackLayout >
                <Grid ColumnDefinitions="*,*,*"
                Padding="20, 20, 20, 6">
                    <Label 
                    Grid.Column="0"
                    Text="Type"/>
                    <Label 
                    Grid.Column="1"
                    Text="Name"/>
                    <Label 
                    Grid.Column="2"
                    Text="Date"/>
                </Grid>

                <BoxView HeightRequest="1"
                Color="Gray"
                VerticalOptions="Fill"
                Margin="20,0"/>
            </VerticalStackLayout>

            <CollectionView x:Name="AssessmentListView"
                            ItemsSource="{Binding Assessments}"
                            SelectionMode="Single"
                            SelectionChanged="OnAssessmentSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,*,*"
                              Padding="20, 20, 20, 0">
                            <Label Grid.Column="0" 
                                   Text="{Binding Type}"
                                   TextColor="#997304"
                                   FontSize="16"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding Name}"/>
                            <Label Grid.Column="2" 
                                   Text="{Binding DateRange}"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <Button Grid.Row="1" 
            BackgroundColor="#426929"
            Clicked="OnAddAssessment"
            Text="Add Assessment"
            HorizontalOptions="Start"
            Margin="20"/>

    </Grid>
    </ScrollView>
    
</ContentPage>